# Copy this to .env.local and fill in your values

# Vercel Postgres (or any Postgres connection string)
POSTGRES_URL=

# Email service for lead routing (choose one)
RESEND_API_KEY=
# SENDGRID_API_KEY=

# Stripe for billing (premium/featured plans)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Analytics — set ONE of these (leave blank to disable)
# Google Analytics 4 (free): paste your Measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
# Plausible (paid, privacy-friendly): your domain, e.g. dallaslights.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
